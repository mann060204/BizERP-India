{
  "version": 2,
  "builds": [
    {
      "src": "erp-frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "erp-backend/src/server.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "erp-backend/src/server.ts"
    },
    {
      "src": "/(.*)",
      "dest": "erp-frontend/$1"
    }
  ]
}
